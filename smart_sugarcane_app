            Card(child: Center(child: Text("🗺 GPS"))),
            Card(child: Center(child: Text("📷 Inspection"))),
            Card(child: Center(child: Text("📄 E-Contract"))),
            Card(child: Center(child: Text("🔧 Maintenance"))),
            Card(child: Center(child: Text("📊 Reports"))),
          ],
        ),
      );
    }
